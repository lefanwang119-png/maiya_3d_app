<view class="shop-page">
  <view class="status-bar"></view>

  <view class="shop-nav">
    <image class="logo" src="{{images.logo}}" mode="aspectFit" />
    <view class="search-pill">
      <text class="search-icon">⌕</text>
      <input value="{{searchText}}" placeholder="搜索商品" bindinput="onSearchInput" />
    </view>
  </view>

  <view class="filter-tabs">
    <view wx:for="{{categories}}" wx:key="item" class="filter-tab {{activeCategory === item ? 'filter-tab--active' : ''}}" data-value="{{item}}" bindtap="chooseCategory">{{item}}</view>
    <view class="filter-icon" bindtap="openFilterSheet">☰</view>
  </view>

  <scroll-view class="shop-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="section-row"><view class="section-title">精选好物</view><view class="sort-pill" bindtap="switchSort">{{sortMode}}</view></view>
    <view class="product-grid">
      <view wx:for="{{visibleProducts}}" wx:key="id" class="product-card" data-id="{{item.id}}" bindtap="openProduct">
        <view class="product-image-wrap"><image class="product-image" src="{{item.image}}" mode="aspectFill" /><view class="tag"><text class="badge-star">★</text><text>{{item.tag}}</text></view></view>
        <view class="product-name">{{item.name}}</view>
        <view class="product-meta"><image src="{{images.avatar}}" mode="aspectFill" /><text>官方</text><view>赞 33</view><view>下载 99</view></view>
      </view>
    </view>
    <view wx:if="{{searchText && !visibleProducts.length}}" class="empty-search"><view>暂无商品</view><text>换个关键词试试</text></view>
  </scroll-view>

  <view wx:if="{{!showDetail}}" class="cart-bar {{hasCart ? 'cart-bar--active' : ''}}" bindtap="checkout">
    <view class="cart-copy"><view>{{cartTitle}}</view><text>{{cartSummary}}</text></view>
    <view class="checkout-btn">去结算</view>
  </view>

  <view wx:if="{{showFilter}}" class="sheet-mask" bindtap="closeFilterSheet">
    <view class="filter-panel" catchtap="noop">
      <view class="filter-title">商品分类</view>
      <view class="type-row"><text wx:for="{{filterCategories}}" wx:key="item" class="{{selectedCategoryFilter === item ? 'choice-text-active' : ''}}" data-value="{{item}}" bindtap="chooseCategoryFilter">{{item}}</text></view>
      <button class="confirm-btn" bindtap="closeFilterSheet">确定</button>
    </view>
  </view>

  <view wx:if="{{showDetail}}" class="detail-page">
    <view class="detail-status"><view class="detail-back" bindtap="closeDetail">返回</view><view class="detail-owner">商品详情</view></view>
    <scroll-view class="detail-scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <image class="detail-hero" src="{{selectedProduct.image}}" mode="aspectFill" />
      <view class="detail-content">
        <view class="detail-title-row"><view class="detail-badge">精选</view><view class="detail-title">{{selectedProduct.name}}</view></view>
        <view class="detail-tags"><text data-value="全部" bindtap="jumpTag">精品</text><text data-value="{{selectedProduct.category}}" bindtap="jumpTag">{{selectedProduct.category}}</text></view>
        <view class="detail-desc">{{selectedProduct.desc}}</view>
        <view class="detail-date">发布时间：2026.04.23</view>
        <view class="comment-title">评论（{{comments.length}}）</view>
        <view class="comment-editor"><input value="{{commentText}}" placeholder="评价一下这个商品" bindinput="onCommentInput" /><button bindtap="publishComment">发布</button></view>
        <view wx:for="{{comments}}" wx:key="id" class="comment-row"><image src="{{item.avatar}}" mode="aspectFill" /><view><view class="comment-head">{{item.author}} <text>{{item.date}}</text></view><view class="comment-copy">{{item.content}}</view></view></view>
      </view>
    </scroll-view>
    <view class="detail-bottom"><view class="detail-stat {{selectedLiked ? 'detail-stat--active' : ''}}" bindtap="toggleLike">点赞</view><view class="detail-stat {{selectedFavorited ? 'detail-stat--active' : ''}}" bindtap="toggleFavorite">收藏</view><button data-id="{{selectedProduct.id}}" bindtap="addToCart">加入购物车</button><button class="primary" bindtap="buyNow">购买 {{selectedProduct.price}}</button></view>
  </view>
</view>
