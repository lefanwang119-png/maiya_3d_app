<view class="generated-page">
  <view class="generated-top">
    <view class="back-btn" bindtap="handleBack">‹</view>
    <view>
      <view class="page-title">AI 模型管理</view>
      <view class="page-sub">提交发布申请，管理员审核通过后进入精选模型推荐</view>
    </view>
  </view>

  <scroll-view class="generated-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:if="{{!models.length}}" class="empty-card">
      <view class="empty-title">还没有 AI 生成模型</view>
      <view class="empty-sub">生成成功后会自动出现在这里。</view>
    </view>

    <view class="admin-entry" bindtap="openAdminReview">管理员审核入口</view>

    <view wx:for="{{models}}" wx:key="id" class="manage-card">
      <view class="cover-wrap">
        <image class="model-cover" src="{{item.image}}" mode="aspectFill" />
        <view class="status-pill {{item.isPublic ? 'status-pill--public' : 'status-pill--hidden'}}">
          {{item.statusText}}
        </view>
      </view>

      <view class="model-body">
        <view class="model-title">{{item.title}}</view>
        <view class="model-desc">{{item.description}}</view>
        <view class="model-meta">{{item.format}} · {{item.createdAtText}} · {{item.actionHint}}</view>

        <view class="action-row">
          <button class="ghost-btn" data-id="{{item.id}}" bindtap="openDetail">详情</button>
          <button class="ghost-btn" data-id="{{item.id}}" bindtap="openResult">结果</button>
          <button class="publish-btn {{item.isPublic ? 'publish-btn--hide' : 'publish-btn--show'}}" data-id="{{item.id}}" bindtap="toggleReview">
            {{item.actionText}}
          </button>
        </view>

        <button class="delete-btn" data-id="{{item.id}}" bindtap="deleteModel">删除</button>
      </view>
    </view>
  </scroll-view>
</view>
