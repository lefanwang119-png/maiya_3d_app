<view class="detail-page">
  <view class="detail-nav">
    <button class="nav-back" bindtap="goBack">‹</button>
    <view class="nav-title">模型详情</view>
  </view>

  <scroll-view class="detail-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <image class="hero" src="{{model.image || assets.previewImageUrl || defaultImage}}" mode="aspectFill" />
    <view class="content">
      <view class="badge-row">
        <text class="badge">精选</text>
        <text class="badge muted">{{model.category || '模型'}}</text>
      </view>
      <view class="title">{{model.title || 'MAIYA 3D 模型'}}</view>
      <view class="desc">{{model.description || '可在线预览、拖动查看并导出模型文件。'}}</view>
      <view class="meta">
        <text>格式 {{primaryFormat}}</text>
        <text wx:if="{{assets.jobId}}">任务 {{assets.jobId}}</text>
      </view>

      <view class="actions">
        <button class="primary" bindtap="openPreview">模型预览</button>
        <button bindtap="exportGlb">导出 GLB</button>
        <button bindtap="exportObj">导出 OBJ</button>
        <button bindtap="exportPreview">导出预览图</button>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{preparedExportPath}}" class="export-ready">
    <view>
      <view class="export-title">{{preparedExportName}}</view>
      <text>文件已准备好，点击右侧打开导出面板。</text>
    </view>
    <button bindtap="openPreparedExport">打开导出</button>
  </view>

  <view wx:if="{{showPreview}}" class="preview-mask" catchtouchmove="noop" bindtap="closePreview">
    <view class="preview-panel" catchtap="noop">
      <view class="preview-head">
        <view>
          <view class="preview-title">模型预览</view>
          <text>拖动模型可全角度查看</text>
        </view>
        <button bindtap="closePreview">关闭</button>
      </view>
      <view class="preview-canvas" catchtouchmove="noop">
        <glb-viewer
          wx:if="{{previewSrc || previewFileID}}"
          src="{{previewSrc}}"
          file-id="{{previewFileID}}"
          bind:error="onPreviewError"
        />
        <view wx:else class="loading">{{preparingPreview ? '正在加载 3D 模型...' : '暂无可预览的 GLB 文件'}}</view>
      </view>
    </view>
  </view>
</view>
