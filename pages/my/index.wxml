<view class="my-page">
  <view class="status-bar"></view>

  <view class="my-nav">
    <image class="logo" src="{{images.logo}}" mode="aspectFit" />
    <view class="nav-title">我的</view>
  </view>

  <scroll-view class="my-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="user-panel">
      <view class="profile" bindtap="handleProfileTap">
        <image class="profile-avatar" src="{{isLoad && personalInfo.image ? personalInfo.image : images.avatar}}" mode="aspectFill" />
        <view class="profile-copy">
          <view class="profile-name">{{isLoad ? personalInfo.name : '点击登录'}}</view>
          <view class="profile-sub">{{isLoad ? '管理你的模型、积分和收益' : '登录后同步积分、订单和生成记录'}}</view>
        </view>
        <view class="setting-dot">⚙</view>
      </view>

      <view class="account-row">
        <view class="points-entry">
          <text class="points-icon">★</text>
          <view>
            <view class="points-label">剩余积分</view>
            <view class="points-value">{{pointsBalance}}</view>
          </view>
          <view class="points-add" bindtap="openRecharge">+</view>
        </view>

        <view class="income-entry" bindtap="openIncome">
          <view class="income-label">创作收入</view>
          <view class="income-value">¥{{incomeTotal}}</view>
        </view>

        <view class="order-entry" bindtap="openOrders">我的订单</view>
      </view>
    </view>

    <view class="section-head">
      <view class="section-title">我的模型</view>
      <view class="manage-entry" bindtap="openGeneratedManage">管理AI模型</view>
    </view>

    <view class="model-grid">
      <view wx:for="{{myModels}}" wx:key="id" class="model-card" data-id="{{item.id}}" bindtap="openModel">
        <view class="image-wrap">
          <image class="model-image" src="{{item.image}}" mode="aspectFill" />
          <view class="featured-ribbon">
            <text class="badge-star">★</text>
            <text>{{item.isGenerated ? 'AI' : '精选'}}</text>
          </view>
          <view class="publish-status {{item.isPublic ? 'publish-status--public' : 'publish-status--hidden'}}">{{item.statusText}}</view>
        </view>

        <view class="model-title">{{item.title}}</view>
        <view class="model-meta">
          <view>♥ {{item.likes}}</view>
          <view>↓ {{item.downloads}}</view>
        </view>

        <button
          class="model-publish-btn {{item.isPublic ? 'model-publish-btn--hide' : 'model-publish-btn--show'}}"
          data-id="{{item.id}}"
          catchtap="toggleMyModelPublish"
        >{{item.actionText}}</button>
      </view>

      <view class="model-card upload-card" bindtap="openUploadPanel">
        <view class="upload-card__icon">+</view>
        <view class="upload-card__title">上传本地模型</view>
        <view class="upload-card__sub">支持 GLB / OBJ、封面图和简介</view>
      </view>
    </view>

    <view class="points-log" wx:if="{{pointLogs.length}}">
      <view class="section-title">最近记录</view>
      <view wx:for="{{pointLogs}}" wx:key="id" class="points-log__row">
        <view>
          <view class="points-log__name">{{item.title}}</view>
          <view class="points-log__sub">余额 {{item.balance}}</view>
        </view>
        <view class="points-log__num {{item.pointsClass}}">{{item.pointsText}}</view>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{showUploadPanel}}" class="upload-mask" bindtap="closeUploadPanel">
    <view class="upload-panel" catchtap="noop">
      <view class="upload-title">上传本地模型</view>
      <view class="upload-sub">保存后会出现在我的模型，可继续申请发布审核。</view>

      <view class="upload-field">
        <view class="upload-label">模型名称</view>
        <input class="upload-input" value="{{uploadForm.title}}" placeholder="请输入模型名称" bindinput="onUploadTitleInput" />
      </view>

      <view class="upload-field">
        <view class="upload-label">模型简介</view>
        <textarea class="upload-textarea" value="{{uploadForm.description}}" placeholder="简单描述模型特点、用途或打印建议" bindinput="onUploadDescInput" />
      </view>

      <view class="upload-picker-row">
        <view class="upload-picker" bindtap="chooseUploadCover">
          <image wx:if="{{uploadForm.image}}" class="upload-preview" src="{{uploadForm.image}}" mode="aspectFill" />
          <view wx:else>
            <view class="upload-picker__icon">+</view>
            <view class="upload-picker__text">上传图片</view>
          </view>
        </view>

        <view class="upload-file" bindtap="chooseUploadFile">
          <view class="upload-file__type">{{uploadForm.format || 'GLB/OBJ'}}</view>
          <view class="upload-file__name">{{uploadForm.fileName || '选择模型文件'}}</view>
        </view>
      </view>

      <view class="upload-actions">
        <button class="upload-cancel" bindtap="closeUploadPanel">取消</button>
        <button class="upload-save" loading="{{isSavingUpload}}" bindtap="saveUploadedModel">保存模型</button>
      </view>
    </view>
  </view>

  <view wx:if="{{showRecharge}}" class="recharge-mask" bindtap="closeRecharge">
    <view class="recharge-panel" catchtap="noop">
      <view class="recharge-title">充值积分</view>
      <view class="recharge-sub">0.1 元 = 1 积分，用于 MAIYA 3D 生成</view>
      <view class="recharge-grid">
        <view wx:for="{{rechargeOptions}}" wx:key="points" class="recharge-option" data-points="{{item.points}}" bindtap="recharge">
          <view class="recharge-badge">{{item.badge}}</view>
          <view class="recharge-points">{{item.points}} 积分</view>
          <view class="recharge-price">¥{{item.price}}</view>
        </view>
      </view>
      <view class="recharge-note">{{rechargeNote}}</view>
    </view>
  </view>
</view>
